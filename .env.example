# ==========================================
# APP SECRETS & KEYS
# ==========================================
# Make a copy of this file and rename it to `.env`
# DO NOT commit your actual `.env` file to GitHub!

# Razorpay Client ID (Public Key)
# Safe to expose in the mobile app bundle, but keep it out of GitHub to prevent scraping
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# NOTE: Razorpay Client Secret (Private Key)
# NEVER put your Razorpay Secret Key in this app or in this file!
# The Secret Key must only be used on your backend server.
